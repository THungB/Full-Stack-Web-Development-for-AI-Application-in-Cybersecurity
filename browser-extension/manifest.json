{
  "manifest_version": 3,
  "name": "Spam Detector Assistant",
  "version": "1.0.0",
  "description": "Scan highlighted text with the local spam detection API.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
